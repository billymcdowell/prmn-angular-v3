{
  "name": "prmn-angular-v3",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:ui": "ng build ui",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "storybook": "ng run ui:storybook",
    "build-storybook": "ng run ui:build-storybook --preview-url=/prmn-angular-v3/iframe.html",
    "build-storybook:gh": "STORYBOOK_PUBLIC_PATH=/prmn-angular-v3 ng run ui:build-storybook",
    "postbuild:build-storybook:gh": "perl -i -p -e 's#<head>#<head>\n\t\t<base href='/prmn-angular-v3/'>#' ./storybook-static/index.html"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": false,
  "dependencies": {
    "@angular/cdk": "^21.2.1",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@ng-icons/core": "^33.1.0",
    "@ng-icons/lucide": "^33.1.0",
    "@spartan-ng/brain": "^0.0.1-alpha.649",
    "@storybook/addon-themes": "^10.2.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-angular": "^21.0.0",
    "ngx-sonner": "^3.1.0",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.5.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2003.0",
    "@angular-devkit/build-angular": "^20.3.0",
    "@angular-devkit/core": "^20.3.0",
    "@angular/build": "^20.3.19",
    "@angular/cli": "^20.3.0",
    "@angular/compiler-cli": "^20.3.0",
    "@angular/platform-browser-dynamic": "^20.3.0",
    "@compodoc/compodoc": "^1.2.1",
    "@storybook/addon-a11y": "^10.2.17",
    "@storybook/addon-docs": "^10.2.17",
    "@storybook/addon-mdx-gfm": "^8.6.14",
    "@storybook/angular": "^10.2.17",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^20.3.0",
    "storybook": "^10.2.17",
    "tailwindcss": "4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.2"
  }
}
